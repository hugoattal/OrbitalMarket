{
    "name": "@orbital-market/backend",
    "version": "1.0.0",
    "main": "index.js",
    "author": "Hugo Attal",
    "description": "Orbital Market Backend",
    "license": "none",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/hugoattal/OrbitalMarket.git"
    },
    "scripts": {
        "_node": "node --import @swc-node/register/esm-register --enable-source-maps --env-file .env",
        "dev": "cross-env NODE_ENV=development nodemon -T src/server.ts",
        "clean": "tsc --build --clean",
        "start": "cross-env NODE_ENV=production pnpm run _node -- src/server.ts",
        "api:fab-update": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab",
        "api:fab-update-single": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/single.ts",
        "api:fab-fix-product": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/scripts/fixOldAssets.ts",
        "api:fab-fix-user": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/scripts/fixOldUsers.ts",
        "api:fab-fix-release": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/scripts/fixRelease.ts",
        "api:fab-precise": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/updatePrecise.ts",
        "api:fab-steal": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/scripts/findSteal.ts",
        "api:update-score": "cross-env NODE_ENV=production pnpm run _node -- src/scrapper/fab/updateScore.ts",
        "test": "cross-env NODE_ENV=test vitest",
        "dev:test": "cross-env NODE_ENV=test vitest --ui"
    },
    "_moduleAliases": {
        "@": "./src"
    },
    "dependencies": {
        "@fastify/middie": "^9.3.2",
        "@fastify/static": "^9.1.3",
        "@luna-park/http-errors": "^1.0.0",
        "async-mutex": "^0.5.0",
        "axios": "^1.18.0",
        "bcryptjs": "^3.0.3",
        "cheerio": "^1.2.0",
        "cors": "^2.8.6",
        "date-fns": "^4.4.0",
        "dotenv": "^17.4.2",
        "es-toolkit": "^1.47.1",
        "escape-html": "^1.0.3",
        "fastify": "^5.8.5",
        "http-errors": "^2.0.1",
        "mongodb": "^7.3.0",
        "mongoose": "^9.7.0",
        "node-cron": "^4.2.1",
        "playwright": "^1.61.0",
        "string-similarity-js": "^2.1.4",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@faker-js/faker": "10.4.0",
        "@luna-park/eslint-config": "^1.3.0",
        "@swc-node/register": "^1.11.1",
        "@types/bcryptjs": "^3.0.0",
        "@types/cors": "^2.8.19",
        "@types/dotenv-safe": "^9.1.0",
        "@types/escape-html": "^1.0.4",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.3",
        "@types/node-cron": "^3.0.11",
        "@types/uuid": "^11.0.0",
        "@vitest/ui": "4.1.9",
        "cross-env": "^10.1.0",
        "eslint": "^10.5.0",
        "json-schema-faker": "0.6.2",
        "mongodb-memory-server": "^11.2.0",
        "nodemon": "^3.1.14",
        "sinon": "^22.0.0",
        "type-fest": "^5.7.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16",
        "vitest": "4.1.9"
    }
}
